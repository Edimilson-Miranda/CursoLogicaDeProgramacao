Algoritmo "soma"


Var
          x, y, soma : inteiro


Inicio

          escreval("Vamos fazer uma soma de dois números inteiro: ")
          escreva("Digite o valor de X: ")
          leia(x)
          escreva("Digite o valor de Y: ")
          leia(y)

          soma <-  x + y
          
          escreval("SOMA = ", soma)


Fimalgoritmo